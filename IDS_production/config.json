{
    "monitoring": {
        "sources": [
            {
                "path": "/var/log/auth.log",
                "domain": "ssh",
                "enabled": true
            },
            {
                "path": "test_logs.txt",
                "domain": "linux",
                "enabled": true
            }
        ],
        "window_size": 20,
        "min_lines_for_inference": 5
    },
    "detection": {
        "model_path": "model/production.joblib",
        "global_threshold": 0.25,
        "confidence_blocking_threshold": 0.40
    },
    "response": {
        "enabled": true,
        "block_duration_seconds": 3600,
        "iptables_enabled": true
    },
    "storage": {
        "db_path": "ids_history.db"
    }
}